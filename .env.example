# ASP.NET Core settings
ASPNETCORE_ENVIRONMENT=Development

# SQL Server settings
SQL_SERVER_HOST=sqlserver
SQL_SERVER_DATABASE=HealthcareCareCoordination
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=Change_this_password_locally_only
SQL_CONNECTION_STRING=Server=localhost,1433;Database=HealthcareCareCoordination;User Id=sa;Password=Change_this_password_locally_only;TrustServerCertificate=True;

# Cosmos DB settings
COSMOS_MODE=Mock
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=HealthcareCareCoordination

# Clinical AI settings
CLINICAL_AI_PROVIDER_MODE=Mock
AZURE_AI_LANGUAGE_ENDPOINT=
AZURE_AI_LANGUAGE_KEY=
AZURE_AI_LANGUAGE_REGION=
AZURE_AI_LANGUAGE_API_VERSION=
AZURE_AI_LANGUAGE_TIMEOUT_SECONDS=60
AI_PROVIDER=Mock

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Security and RBAC
SECURITY_MODE=Demo
ALLOW_DEMO_HEADERS=true
DEFAULT_DEMO_ROLE=CareCoordinator

# React Frontend settings
VITE_API_BASE_URL=http://localhost:5080
