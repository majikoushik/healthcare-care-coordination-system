# =============================================================================
# Healthcare Care Coordination System — Local Environment Template
# Copy this file to .env and fill in values for local development.
# .env is git-ignored; never commit real secrets.
# =============================================================================

# ASP.NET Core settings
ASPNETCORE_ENVIRONMENT=Development

# ---------------------------------------------------------------------------
# SQL Server (Fix 3)
# ASP.NET Core reads ConnectionStrings:DefaultConnection via the
# double-underscore env var: ConnectionStrings__DefaultConnection
# Docker Compose services use this exact key name.
# ---------------------------------------------------------------------------
SQL_SERVER_HOST=sqlserver
SQL_SERVER_DATABASE=HealthcareCareCoordination
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=Change_this_password_locally_only

# Use this key for Docker Compose and direct dotnet run with env vars:
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=HealthcareCareCoordination;User Id=sa;Password=Change_this_password_locally_only;TrustServerCertificate=True;

# ---------------------------------------------------------------------------
# Azure Cosmos DB (Cosmos DB-backed services use COSMOS_MODE=Mock locally)
# ---------------------------------------------------------------------------
COSMOS_MODE=Mock
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=HealthcareCareCoordination

# ---------------------------------------------------------------------------
# Clinical AI (Fix 8)
# CLINICAL_AI_PROVIDER_MODE=Mock is the default for local dev and CI.
# AzureTextAnalyticsForHealthProvider is a readiness placeholder only —
# it does NOT make real Azure AI Language calls without a real SDK integration.
# ---------------------------------------------------------------------------
CLINICAL_AI_PROVIDER_MODE=Mock
AI_PROVIDER=Mock
AZURE_AI_LANGUAGE_ENDPOINT=
AZURE_AI_LANGUAGE_KEY=
AZURE_AI_LANGUAGE_REGION=
AZURE_AI_LANGUAGE_API_VERSION=
AZURE_AI_LANGUAGE_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# Application Insights (optional — omit for local development)
# ---------------------------------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---------------------------------------------------------------------------
# Security and RBAC — Demo Mode (Fix 9)
# Code binds configuration.GetSection("Security") which maps to
# Security__Mode, Security__AllowDemoHeaders, Security__DefaultDemoRole
# (ASP.NET Core double-underscore env var convention for nested sections).
# ---------------------------------------------------------------------------
Security__Mode=Demo
Security__AllowDemoHeaders=true
Security__DefaultDemoRole=CareCoordinator

# ---------------------------------------------------------------------------
# Audit API base URL (Fix 4)
# For direct dotnet run (local): http://localhost:5085
# For Docker Compose: set to http://audit-api:8080 (handled in compose file)
# ---------------------------------------------------------------------------
AuditApi__BaseUrl=http://localhost:5085

# ---------------------------------------------------------------------------
# React Frontend — per-service API URLs (Fix 1)
# These must start with VITE_ to be injected into the Vite build.
# For local development (npm run dev), set these to localhost ports.
# For Docker Compose, the compose file overrides these with service names.
# ---------------------------------------------------------------------------
VITE_PATIENT_API_URL=http://localhost:5080
VITE_PROVIDER_API_URL=http://localhost:5081
VITE_APPOINTMENT_API_URL=http://localhost:5082
VITE_CARE_PLAN_API_URL=http://localhost:5083
VITE_CLINICAL_INSIGHTS_API_URL=http://localhost:5084
VITE_AUDIT_API_URL=http://localhost:5085
VITE_NOTIFICATION_API_URL=http://localhost:5086
