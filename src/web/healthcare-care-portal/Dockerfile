# Build stage
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .

# Receive build args and export as env vars for Vite build
ARG VITE_PATIENT_API_URL
ARG VITE_PROVIDER_API_URL
ARG VITE_APPOINTMENT_API_URL
ARG VITE_CARE_PLAN_API_URL
ARG VITE_CLINICAL_INSIGHTS_API_URL
ARG VITE_AUDIT_API_URL
ARG VITE_NOTIFICATION_API_URL

ENV VITE_PATIENT_API_URL=$VITE_PATIENT_API_URL
ENV VITE_PROVIDER_API_URL=$VITE_PROVIDER_API_URL
ENV VITE_APPOINTMENT_API_URL=$VITE_APPOINTMENT_API_URL
ENV VITE_CARE_PLAN_API_URL=$VITE_CARE_PLAN_API_URL
ENV VITE_CLINICAL_INSIGHTS_API_URL=$VITE_CLINICAL_INSIGHTS_API_URL
ENV VITE_AUDIT_API_URL=$VITE_AUDIT_API_URL
ENV VITE_NOTIFICATION_API_URL=$VITE_NOTIFICATION_API_URL

RUN npm run build

# Serve stage
FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
